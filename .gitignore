node_modules/
tests/fixtures/source/
tests/fixtures/baked/
tests/fixtures/manifest.json
tests/fixtures/manifest.live.json

# Vitest snapshots are derived from the live-oracle corpus and contain
# fixture-extracted data ; auto-regenerated when contributors run the
# bake + test:live path locally.
tests/**/__snapshots__/

# Local dev env
.env
.env.local
*.log
.DS_Store

# Build output (none today, reserve for future)
dist/

# Browser bench staged artifacts — regenerated by `npm run bench:browser`
# from the current dist bundle + GR2_FOLDER (the .gr2 corpus is itself
# gitignored, so committing copies would commit gitignored binaries).
bench/browser/granny-ro*.js
bench/browser/fixtures/
bench/browser/fixtures.json

# Wine shim build artifacts (cross-compiled via mingw).
# shim/prebuilt/ is intentionally NOT ignored — it ships the canonical
# i386 PE binary so hosts without mingw can run wine-based checks.
shim/*.exe
shim/runtime/
